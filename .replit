modules = ["nodejs-20", "web", "postgresql-16"]
run = "npm run dev"
hidden = [".config", ".git", "generated-icon.png", "node_modules", "dist"]

[nix]
channel = "stable-24_05"

[deployment]
deploymentTarget = "autoscale"
build = ["sh", "-c", "npm ci && npm run build"]
run = ["sh", "-c", "NODE_ENV=production node dist/index.js"]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 35453
externalPort = 8000

[[ports]]
localPort = 35813
externalPort = 8008

[[ports]]
localPort = 36703
externalPort = 6800

[[ports]]
localPort = 37795
externalPort = 3001

[[ports]]
localPort = 38715
externalPort = 4200

[[ports]]
localPort = 39603
externalPort = 3003

[[ports]]
localPort = 40833
externalPort = 6000

[[ports]]
localPort = 43379
externalPort = 5000

[[ports]]
localPort = 44529
externalPort = 3000

[[ports]]
localPort = 44603
externalPort = 3002

[[ports]]
localPort = 45823
externalPort = 5173

[workflows]
runButton = "Local Development"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
agentRequireRestartOnSave = false

[[workflows.workflow.tasks]]
task = "packager.installForAll"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Build and Install Dependencies"
author = 41163872
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "apt-get update && apt-get install -y libuuid1 && npm install && npm run build"

[[workflows.workflow]]
name = "Build and Start"
author = 41163872
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=production node dist/index.js"

[[workflows.workflow]]
name = "Production Build and Start"
author = 41163872
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm install"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run build"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=production node dist/index.js"

[[workflows.workflow]]
name = "Local Development"
author = 41163872
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"

[agent]
integrations = ["javascript_openai_ai_integrations:1.0.0"]
